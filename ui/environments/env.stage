# UI Staging Environment Configuration

# App Configuration
APP_NAME="Vyom Stage"
APP_ENVIRONMENT="stage"
APP_API_BASE_URL="https://vyom-api.concierge.stage.razorpay.in"
APP_UI_BASE_URL="https://vyom.concierge.stage.razorpay.in"
APP_UI_PORT=8001
APP_DEBUG=false

# Performance Configuration
PERFORMANCE_API_TIMEOUT=8000
PERFORMANCE_POLLING_INTERVAL=10000
PERFORMANCE_PAGINATION_SIZE=20

# Features Configuration
FEATURES_ENABLE_DARK_MODE=true
FEATURES_ENABLE_AUTO_REFRESH=true
FEATURES_ENABLE_NOTIFICATIONS=true

# Authentication Configuration
AUTH_USERNAME="dashboard"
AUTH_PASSWORD="stage_dashboard_pass"

# Logging Configuration
LOGGING_LEVEL="warn"
LOGGING_LOG_API_REQUESTS=false
