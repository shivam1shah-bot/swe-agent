# UI Default Base Configuration
# This file contains default values that are overridden by environment-specific configs

# App Configuration
APP_NAME="Vyom"
APP_ENVIRONMENT="default"
APP_API_BASE_URL="http://localhost:8002"
# Note: Discover API now uses the main API via Python proxy (api/v1/discover/*)
# This is deprecated and will be removed in a future update
APP_DISCOVER_API_BASE_URL="http://localhost:8002"
APP_UI_BASE_URL="http://localhost:8001"
APP_UI_PORT=8001
APP_DEBUG=false

# Performance Configuration
PERFORMANCE_API_TIMEOUT=8000
PERFORMANCE_POLLING_INTERVAL=15000
PERFORMANCE_PAGINATION_SIZE=15

# Features Configuration
FEATURES_ENABLE_DARK_MODE=true
FEATURES_ENABLE_AUTO_REFRESH=true
FEATURES_ENABLE_NOTIFICATIONS=true

# Authentication Configuration
AUTH_USERNAME="dashboard"
AUTH_PASSWORD="dashboard123"

# Logging Configuration
LOGGING_LEVEL="info"
LOGGING_LOG_API_REQUESTS=false
