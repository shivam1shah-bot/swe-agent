# UI Development Docker Environment Configuration

# App Configuration
APP_NAME="Vyom Dev Docker"
APP_ENVIRONMENT="dev_docker"
APP_API_BASE_URL="http://localhost:28002"
# Note: Discover API now uses the main API via Python proxy (api/v1/discover/*)
APP_DISCOVER_API_BASE_URL="http://localhost:28002"
APP_UI_BASE_URL="http://localhost:28001"
APP_UI_PORT=28001
APP_DEBUG=true

# Performance Configuration
PERFORMANCE_API_TIMEOUT=10000
PERFORMANCE_POLLING_INTERVAL=5000
PERFORMANCE_PAGINATION_SIZE=10

# Features Configuration
FEATURES_ENABLE_DARK_MODE=true
FEATURES_ENABLE_AUTO_REFRESH=true
FEATURES_ENABLE_NOTIFICATIONS=true

# Authentication Configuration
AUTH_USERNAME="dashboard"
AUTH_PASSWORD="dashboard123"

# Logging Configuration
LOGGING_LEVEL="debug"
LOGGING_LOG_API_REQUESTS=true
