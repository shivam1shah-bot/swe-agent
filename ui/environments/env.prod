# UI Production Environment Configuration

# App Configuration
APP_NAME="Vyom"
APP_ENVIRONMENT="prod"
APP_API_BASE_URL="https://swe-agent-api.prod.razorpay.in"
# Note: Discover API now uses the main API via Python proxy (api/v1/discover/*)
APP_DISCOVER_API_BASE_URL="https://swe-agent-api.prod.razorpay.in"
APP_UI_BASE_URL="https://swe-agent.prod.razorpay.in"
APP_UI_PORT=8001
APP_DEBUG=false

# Performance Configuration
PERFORMANCE_API_TIMEOUT=5000
PERFORMANCE_POLLING_INTERVAL=30000
PERFORMANCE_PAGINATION_SIZE=25

# Features Configuration
FEATURES_ENABLE_DARK_MODE=true
FEATURES_ENABLE_AUTO_REFRESH=false
FEATURES_ENABLE_NOTIFICATIONS=true

# Authentication Configuration
AUTH_USERNAME="dashboard"
AUTH_PASSWORD="prod_dashboard_secure_pass"

# Logging Configuration
LOGGING_LEVEL="error"
LOGGING_LOG_API_REQUESTS=false
