# SWE Agent Webhook Receiver - Production
# Lightweight image: only FastAPI + Redis + TOML (no AI/ML/GitHub deps)

FROM python:3.13-alpine3.22

WORKDIR /app

# Copy slim requirements (not the full requirements.txt)
COPY requirements.webhook_receiver.txt .

RUN apk update && apk add --no-cache \
    curl \
    ca-certificates \
    bash

RUN curl -LsSf --insecure https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

RUN uv pip install --system -r requirements.webhook_receiver.txt

COPY . .

ENV SRC_DIR=app
ENV LOG_DIR=app/tmp/logs
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TZ=Asia/Kolkata
ENV APP_NAME=swe-agent-webhook-receiver

EXPOSE 8004

CMD ["python", "commands/webhook_receiver.py"]
