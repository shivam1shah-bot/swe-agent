# Dockerfile for the SWE Agent Scheduler Worker
# Lightweight — runs APScheduler + Redis, does NOT need Claude Code, GitHub CLI, or Go toolchain.

FROM python:3.13-alpine3.22

WORKDIR /app

# Copy requirements first for better caching
COPY requirements.txt .

# Minimal system deps — only what Python packages need
RUN apk update && apk add --no-cache \
    cmake \
    make \
    gcc \
    g++ \
    curl \
    curl-dev \
    ca-certificates \
    git \
    musl-dev \
    bash

# Install uv for faster Python dependency installs
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

# Install Python packages with optional private repo auth
RUN --mount=type=secret,id=github_token,required=false \
    if [ -f /run/secrets/github_token ]; then \
        export GITHUB_TOKEN=$(cat /run/secrets/github_token); \
    fi && \
    if [ -n "$GITHUB_TOKEN" ]; then \
        sed "s|https://github.com/razorpay/ai-pr-reviewer|https://x-access-token:${GITHUB_TOKEN}@github.com/razorpay/ai-pr-reviewer|g" requirements.txt > /tmp/requirements_auth.txt && \
        uv pip install --system -r /tmp/requirements_auth.txt && \
        rm /tmp/requirements_auth.txt; \
    else \
        echo "WARNING: GITHUB_TOKEN not provided, installing without private repo authentication" && \
        uv pip install --system -r requirements.txt || true; \
    fi

# Environment variables
ENV APP_NAME=swe-agent-scheduler
ENV SRC_DIR=app
ENV LOG_DIR=app/tmp/logs
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TZ=Asia/Kolkata

# Copy application code
COPY . .

# Build-specific ARGs
ARG GIT_COMMIT_HASH
ENV GIT_COMMIT_HASH=${GIT_COMMIT_HASH}

# Run the scheduler (APScheduler + Redis, not an SQS worker)
CMD ["python", "commands/scheduler.py"]
