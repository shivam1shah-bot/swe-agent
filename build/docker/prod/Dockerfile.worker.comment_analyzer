# Dockerfile for the SWE Agent Comment Analyzer Worker

FROM python:3.13-alpine3.22

WORKDIR /app

# Copy requirements first for better caching
COPY requirements.txt .

# Install additional dependencies including Node.js, npm, bash, and GitHub CLI
RUN apk update && apk add --no-cache \
    cmake \
    make \
    gcc \
    g++ \
    curl \
    curl-dev \
    ca-certificates \
    git \
    musl-dev \
    nodejs \
    npm \
    bash \
    github-cli

# Install uv for faster Python dependency installs
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

# Install Python packages via uv with authentication for private repos
# The GITHUB_TOKEN allows HTTPS access to shivam1shah-bot/ai-pr-reviewer private repo
# Token is mounted as a secret to avoid cache invalidation when token changes
RUN --mount=type=secret,id=github_token,required=false \
    if [ -f /run/secrets/github_token ]; then \
        export GITHUB_TOKEN=$(cat /run/secrets/github_token); \
    fi && \
    if [ -n "$GITHUB_TOKEN" ]; then \
        sed "s|https://github.com/shivam1shah-bot/ai-pr-reviewer|https://x-access-token:${GITHUB_TOKEN}@github.com/shivam1shah-bot/ai-pr-reviewer|g" requirements.txt > /tmp/requirements_auth.txt && \
        uv pip install --system -r /tmp/requirements_auth.txt && \
        rm /tmp/requirements_auth.txt; \
    else \
        echo "WARNING: GITHUB_TOKEN not provided, installing without private repo authentication" && \
        uv pip install --system -r requirements.txt || true; \
    fi

# Install Claude Code globally via npm
RUN npm install -g @anthropic-ai/claude-code

# Copy Claude Code settings for consistent behavior across dev/prod
RUN mkdir -p /root/.claude
COPY src/agents/terminal_agents/claude-code-settings.json /root/.claude/settings.json

# Create Claude wrapper script to fix BusyBox env compatibility
RUN mv /usr/local/bin/claude /usr/local/bin/claude-original && \
    echo '#!/bin/bash' > /usr/local/bin/claude && \
    echo 'export SHELL=/bin/bash' >> /usr/local/bin/claude && \
    echo 'exec node --no-warnings --enable-source-maps /usr/local/bin/claude-original "$@"' >> /usr/local/bin/claude && \
    chmod +x /usr/local/bin/claude

# Set static environment variables (before source copy for better caching)
ENV APP_NAME=swe-agent-comment-analyzer-worker
ENV SRC_DIR=app
ENV LOG_DIR=app/tmp/logs
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TZ=Asia/Kolkata
ENV GOROOT=/usr/lib/go
ENV GOPATH=/go
ENV PATH=$PATH:$GOROOT/bin:$GOPATH/bin
ENV GOPROXY=direct
ENV GOSUMDB=off

# Create Go workspace directory
RUN mkdir -p $GOPATH

# Copy application code (frequent changes)
COPY . .

# Build-specific ARGs (after source copy)
ARG GIT_COMMIT_HASH
ENV GIT_COMMIT_HASH=${GIT_COMMIT_HASH}

# Command to run the comment analyzer worker
CMD ["python", "commands/comment_analyzer_worker.py"]
