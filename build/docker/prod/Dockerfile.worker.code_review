# Dockerfile for the SWE Agent Code Review Worker

FROM python:3.13-alpine3.22

WORKDIR /app

# Copy requirements first for better caching
COPY requirements.txt .

# Install additional dependencies including Node.js, npm, bash, and GitHub CLI
RUN apk update && apk add --no-cache \
    cmake \
    make \
    gcc \
    g++ \
    curl \
    curl-dev \
    ca-certificates \
    git \
    musl-dev \
    nodejs \
    npm \
    bash \
    github-cli \
    go \
    golangci-lint

# Install uv for faster Python dependency installs
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

# Install Python packages via uv with authentication for private repos
# The GITHUB_TOKEN allows HTTPS access to razorpay/ai-pr-reviewer private repo
# Token is mounted as a secret to avoid cache invalidation when token changes
RUN --mount=type=secret,id=github_token,required=false \
    if [ -f /run/secrets/github_token ]; then \
        export GITHUB_TOKEN=$(cat /run/secrets/github_token); \
    fi && \
    if [ -n "$GITHUB_TOKEN" ]; then \
        sed "s|https://github.com/razorpay/ai-pr-reviewer|https://x-access-token:${GITHUB_TOKEN}@github.com/razorpay/ai-pr-reviewer|g" requirements.txt > /tmp/requirements_auth.txt && \
        uv pip install --system -r /tmp/requirements_auth.txt && \
        rm /tmp/requirements_auth.txt; \
    else \
        echo "WARNING: GITHUB_TOKEN not provided, installing without private repo authentication" && \
        uv pip install --system -r requirements.txt || true; \
    fi

# Install Claude Code globally via npm
RUN npm install -g @anthropic-ai/claude-code

# Create Claude wrapper script to fix BusyBox env compatibility
RUN mv /usr/local/bin/claude /usr/local/bin/claude-original && \
    echo '#!/bin/bash' > /usr/local/bin/claude && \
    echo 'export SHELL=/bin/bash' >> /usr/local/bin/claude && \
    echo 'exec node --no-warnings --enable-source-maps /usr/local/bin/claude-original "$@"' >> /usr/local/bin/claude && \
    chmod +x /usr/local/bin/claude

# Install Google Cloud CLI (simple Alpine approach)
RUN apk add --no-cache python3 py3-pip wget && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then GCLOUD_ARCH="arm"; else GCLOUD_ARCH="x86_64"; fi && \
    wget -q -O - https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-linux-${GCLOUD_ARCH}.tar.gz | tar -xz -C /opt && \
    ln -s /opt/google-cloud-sdk/bin/gcloud /usr/local/bin/gcloud && \
    ln -s /opt/google-cloud-sdk/bin/gsutil /usr/local/bin/gsutil && \
    ln -s /opt/google-cloud-sdk/bin/bq /usr/local/bin/bq && \
    /opt/google-cloud-sdk/bin/gcloud config set core/disable_usage_reporting true

# Set static environment variables (before source copy for better caching)
ENV APP_NAME=swe-agent-code-review-worker
ENV SRC_DIR=app
ENV LOG_DIR=app/tmp/logs
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TZ=Asia/Kolkata
ENV GOROOT=/usr/lib/go
ENV GOPATH=/go
ENV PATH=$PATH:$GOROOT/bin:$GOPATH/bin
ENV GOPROXY=direct
ENV GOSUMDB=off

# Create Go workspace directory
RUN mkdir -p $GOPATH

# Copy application code (frequent changes)
COPY . .

# Install review helper skills from agent-skills repo (baked into image at build time)
# This ensures skills are available without runtime installation (more reliable)
# Note: git config approach is required because npx skills strips credentials from URLs
RUN --mount=type=secret,id=github_token,required=false \
    mkdir -p .agents/skills .claude/skills/review-helpers && \
    if [ -f /run/secrets/github_token ]; then \
        export GITHUB_TOKEN=$(cat /run/secrets/github_token); \
        git config --global url."https://x-access-token:${GITHUB_TOKEN}@github.com/".insteadOf "https://github.com/"; \
    fi && \
    npx skills add https://github.com/razorpay/agent-skills \
        --skill pre-mortem \
        --env claude \
        --full-depth \
        --yes; \
    EXIT_CODE=$?; \
    if [ -f /run/secrets/github_token ]; then \
        git config --global --unset-all url."https://x-access-token:${GITHUB_TOKEN}@github.com/".insteadOf || true; \
    fi && \
    if [ $EXIT_CODE -ne 0 ]; then \
        echo "ERROR: Failed to install pre-mortem skill (exit code: $EXIT_CODE)"; \
        exit $EXIT_CODE; \
    fi && \
    if [ -L ".claude/skills/pre-mortem" ]; then \
        rm .claude/skills/pre-mortem; \
    fi && \
    ln -s ../../../.agents/skills/pre-mortem .claude/skills/review-helpers/pre-mortem

# Build-specific ARGs (after source copy)
ARG GIT_COMMIT_HASH
ENV GIT_COMMIT_HASH=${GIT_COMMIT_HASH}

# Command to run the code review worker
CMD ["python", "commands/code_review_worker.py"]
